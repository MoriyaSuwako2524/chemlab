    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"xtb_400_coord = np.load(\\\"xtb_400K_coord.npy\\\")\\n\",\n",
    "    \"aimd_400_coord = np.load(\\\"aimd_400K_coord.npy\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"total_coord = np.concatenate((xtb_400_coord, aimd_400_coord))\"\n",
    "   ],\n",
    "   \"id\": \"3bccb7bf9a250a78\",\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": 18\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-02-26T21:58:16.881995700Z\",\n",
    "     \"start_time\": \"2026-02-26T21:58:15.663009300Z\"\n",
    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"import numpy as np\\n\",\n",
    "    \"from sklearn.decomposition import PCA\\n\",\n",
    "    \"import matplotlib.pyplot as plt\\n\",\n",
    "    \"from matplotlib.colors import LogNorm\\n\",\n",
    "    \"\\n\",\n",
    "    \"temps = [300,350, 400,450, 500]\\n\",\n",
    "    \"methods = [\\\"xtb\\\", \\\"aimd\\\"]\\n\",\n",
    "    \"labels = {\\\"xtb\\\": \\\"xTB\\\", \\\"aimd\\\": \\\"AIMD\\\"}\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Load all data\\n\",\n",
    "    \"data = {}\\n\",\n",
    "    \"for method in methods:\\n\",\n",
    "    \"    for T in temps:\\n\",\n",
    "    \"        key = f\\\"{method}_{T}\\\"\\n\",\n",
    "    \"        data[key] = np.load(f\\\"{method}_{T}K_coord.npy\\\")\\n\",\n",
    "    \"        print(f\\\"{key}: {data[key].shape}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Flatten and concatenate all\\n\",\n",
    "    \"all_flat = []\\n\",\n",
    "    \"meta = []  # (method, temp, n_frames)\\n\",\n",
    "    \"for method in methods:\\n\",\n",
    "    \"    for T in temps:\\n\",\n",
    "    \"        key = f\\\"{method}_{T}\\\"\\n\",\n",
    "    \"        flat = data[key].reshape(len(data[key]), -1)\\n\",\n",
    "    \"        all_flat.append(flat)\\n\",\n",
    "    \"        meta.append((method, T, len(flat)))\\n\",\n",
    "    \"\\n\",\n",
    "    \"total_flat = np.concatenate(all_flat)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# PCA on all data together\\n\",\n",
    "    \"pca = PCA(n_components=2)\\n\",\n",
    "    \"projected = pca.fit_transform(total_flat)\\n\",\n",
    "    \"print(f\\\"\\\\nExplained variance: PC1={pca.explained_variance_ratio_[0]:.3f}, PC2={pca.explained_variance_ratio_[1]:.3f}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Split back\\n\",\n",
    "    \"proj = {}\\n\",\n",
    "    \"idx = 0\\n\",\n",
    "    \"for method, T, n in meta:\\n\",\n",
    "    \"    proj[f\\\"{method}_{T}\\\"] = projected[idx:idx+n]\\n\",\n",
    "    \"    idx += n\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"fig, axes = plt.subplots(1, 2, figsize=(14, 5))\\n\",\n",
    "    \"colors_T = {300: \\\"tab:blue\\\", 400: \\\"tab:orange\\\", 500: \\\"tab:red\\\",350:\\\"tab:purple\\\",450: \\\"tab:green\\\"}\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# --- Plot 3: all 6 groups together ---\\n\",\n",
    "    \"fig, ax = plt.subplots(figsize=(8, 6))\\n\",\n",
    "    \"markers = {\\\"xtb\\\": \\\"o\\\", \\\"aimd\\\": \\\"^\\\"}\\n\",\n",
    "    \"for method in methods:\\n\",\n",
    "    \"    for T in temps:\\n\",\n",
    "    \"        key = f\\\"{method}_{T}\\\"\\n\",\n",
    "    \"        p = proj[key]\\n\",\n",
    "    \"        ax.scatter(p[:, 0], p[:, 1], alpha=0.25, s=10,\\n\",\n",
    "    \"                   color=colors_T[T], marker=markers[method],\\n\",\n",
    "    \"                   label=f\\\"{labels[method]} {T}K (n={len(p)})\\\")\\n\",\n",
    "    \"ax.set_xlabel(f\\\"PC1 ({pca.explained_variance_ratio_[0]*100:.1f}%)\\\")\\n\",\n",
    "    \"ax.set_ylabel(f\\\"PC2 ({pca.explained_variance_ratio_[1]*100:.1f}%)\\\")\\n\",\n",
    "    \"ax.set_title(\\\"PCA: all conditions\\\")\\n\",\n",
    "    \"ax.legend(markerscale=3, fontsize=9)\\n\",\n",
    "    \"plt.tight_layout()\\n\",\n",
    "    \"plt.savefig(\\\"pca_all.png\\\", dpi=150)\\n\",\n",
    "    \"plt.show()\"\n",
    "   ],\n",
